<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>LinkedIn Zip Puzzle Helper</title>
  <style>
    :root{
      --bg:#f3f2ef;
      --panel:#ffffff;
      --ink:#1f2328;
      --muted:#667085;
      --line:#d0d5dd;
      --blue:#0a66c2;
      --blue-dark:#064a8f;
      --danger:#d92d20;
      --good:#16803c;
      --cell:46px;
      --radius:18px;
    }

    *{box-sizing:border-box}

    body{
      margin:0;
      font-family: Arial, Helvetica, sans-serif;
      background:var(--bg);
      color:var(--ink);
    }

    header{
      background:#fff;
      border-bottom:1px solid #ddd;
      padding:18px 22px;
      display:flex;
      gap:14px;
      align-items:center;
      position:sticky;
      top:0;
      z-index:10;
    }

    .logo{
      width:38px;
      height:38px;
      border-radius:8px;
      background:var(--blue);
      color:white;
      display:flex;
      align-items:center;
      justify-content:center;
      font-weight:800;
      font-size:23px;
      letter-spacing:-1px;
    }

    h1{
      font-size:22px;
      margin:0;
    }

    .subhead{
      color:var(--muted);
      font-size:14px;
      margin-top:4px;
    }

    main{
      max-width:1220px;
      margin:22px auto;
      padding:0 16px 40px;
      display:grid;
      grid-template-columns: 360px 1fr;
      gap:18px;
      align-items:start;
    }

    .card{
      background:var(--panel);
      border:1px solid #e4e7ec;
      border-radius:var(--radius);
      box-shadow:0 8px 20px rgba(16,24,40,.05);
    }

    .panel{
      padding:18px;
    }

    .panel h2{
      font-size:16px;
      margin:0 0 12px;
    }

    label{
      display:block;
      font-size:13px;
      font-weight:700;
      margin:12px 0 6px;
    }

    input, select, textarea{
      width:100%;
      border:1px solid var(--line);
      border-radius:10px;
      padding:10px 11px;
      font-size:14px;
      font-family:inherit;
      background:white;
      color:var(--ink);
    }

    textarea{
      min-height:110px;
      resize:vertical;
    }

    .row{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
    }

    .btns{
      display:flex;
      flex-wrap:wrap;
      gap:8px;
      margin-top:12px;
    }

    button{
      border:0;
      border-radius:999px;
      padding:10px 14px;
      font-weight:800;
      font-size:14px;
      cursor:pointer;
      background:#eef2f6;
      color:#344054;
      transition:.15s transform, .15s background;
    }

    button:hover{transform:translateY(-1px)}
    button.primary{background:var(--blue); color:white}
    button.primary:hover{background:var(--blue-dark)}
    button.danger{background:#fee4e2; color:#b42318}
    button.good{background:#dcfae6; color:#067647}
    button.active{background:#111827; color:white}
    button:disabled{opacity:.45; cursor:not-allowed; transform:none}

    .small{
      font-size:12px;
      color:var(--muted);
      line-height:1.4;
    }

    .status{
      margin-top:14px;
      padding:12px;
      border-radius:12px;
      background:#f8fafc;
      border:1px solid #eaecf0;
      font-size:13px;
      line-height:1.45;
    }

    .status.good{background:#ecfdf3; border-color:#abefc6; color:#067647}
    .status.bad{background:#fef3f2; border-color:#fecdca; color:#b42318}
    .status.warn{background:#fffaeb; border-color:#fedf89; color:#93370d}

    .board-wrap{
      padding:18px;
      min-height:650px;
      overflow:auto;
    }

    .toolbar{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
      justify-content:space-between;
      align-items:center;
      margin-bottom:16px;
    }

    .legend{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
      color:var(--muted);
      font-size:13px;
    }

    .legend span{
      display:inline-flex;
      align-items:center;
      gap:6px;
    }

    .swatch{
      width:16px;
      height:16px;
      border-radius:5px;
      border:1px solid #bbb;
      background:white;
    }
    .swatch.path{background:linear-gradient(90deg,#c026d3,#ef4444); border:0}
    .swatch.block{background:#24292f}

    .grid-shell{
      background:#f8fafc;
      border:1px solid #e4e7ec;
      border-radius:22px;
      padding:22px;
      display:inline-block;
      max-width:100%;
    }

    #grid{
      display:grid;
      gap:4px;
      user-select:none;
      touch-action:manipulation;
    }

    .cell{
      width:var(--cell);
      height:var(--cell);
      background:white;
      border:1px solid #cfd4dc;
      border-radius:10px;
      position:relative;
      display:flex;
      align-items:center;
      justify-content:center;
      cursor:pointer;
      transition:.08s transform, .08s box-shadow, .08s background;
    }

    .cell:hover{
      transform:scale(1.03);
      box-shadow:0 0 0 3px rgba(10,102,194,.12);
      z-index:2;
    }

    .cell.blocked{
      background:#24292f;
      border-color:#24292f;
    }

    .cell.path{
      background:var(--path-color);
      border-color:rgba(255,255,255,.55);
    }

    .cell.path::after{
      content:attr(data-step);
      position:absolute;
      bottom:3px;
      right:5px;
      font-size:10px;
      font-weight:800;
      color:rgba(255,255,255,.75);
      text-shadow:0 1px 2px rgba(0,0,0,.35);
    }

    .dot{
      width:30px;
      height:30px;
      border-radius:50%;
      background:#050505;
      color:#fff;
      display:flex;
      align-items:center;
      justify-content:center;
      font-weight:900;
      font-size:16px;
      line-height:1;
      position:absolute;
      z-index:3;
      box-shadow:0 0 0 2px white, 0 0 0 4px var(--dot-ring, #c026d3);
    }

    .cell.blocked .dot{display:none}

    .cell.manual-last{
      box-shadow:0 0 0 4px rgba(10,102,194,.35);
    }

    .output{
      margin-top:16px;
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:12px;
    }

    .checkline{
      display:flex;
      align-items:flex-start;
      gap:8px;
      font-size:13px;
      margin-top:12px;
    }

    .checkline input{
      width:auto;
      margin-top:2px;
    }

    details{
      margin-top:14px;
      border-top:1px solid #eaecf0;
      padding-top:14px;
    }

    summary{
      cursor:pointer;
      font-weight:800;
    }

    ol{
      margin:10px 0 0 20px;
      padding:0;
      color:#475467;
      font-size:13px;
      line-height:1.55;
    }

    .pill{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:22px;
      height:22px;
      padding:0 7px;
      border-radius:999px;
      background:#eef2f6;
      font-weight:800;
      font-size:12px;
      color:#344054;
    }

    @media (max-width: 900px){
      main{grid-template-columns:1fr}
      .output{grid-template-columns:1fr}
      :root{--cell:39px}
    }

    @media (max-width: 520px){
      :root{--cell:34px}
      .grid-shell{padding:12px}
      .panel{padding:14px}
      h1{font-size:19px}
    }
  </style>
</head>
<body>
  <header>
    <div class="logo">in</div>
    <div>
      <h1>Zip Puzzle Helper</h1>
      <div class="subhead">Recreate the board, place the numbered dots, then test or solve before playing on LinkedIn.</div>
    </div>
  </header>

  <main>
    <section class="card panel">
      <h2>1) Build the puzzle</h2>

      <div class="row">
        <div>
          <label for="rows">Rows</label>
          <input id="rows" type="number" min="2" max="12" value="7">
        </div>
        <div>
          <label for="cols">Columns</label>
          <input id="cols" type="number" min="2" max="12" value="7">
        </div>
      </div>

      <div class="btns">
        <button class="primary" id="makeGridBtn">Apply Grid</button>
        <button id="sampleBtn">Load Sample</button>
      </div>

      <label for="currentNumber">Current dot number</label>
      <input id="currentNumber" type="number" min="1" max="99" value="1">

      <div class="btns" id="modeBtns">
        <button data-mode="number" class="active">Place Number</button>
        <button data-mode="draw">Draw/Test</button>
        <button data-mode="block">Block Cell</button>
        <button data-mode="erase">Erase</button>
      </div>

      <div class="small" style="margin-top:10px;">
        Tip: most LinkedIn Zip boards do not need blocked cells. Only use <b>Block Cell</b> if your puzzle has unusable squares.
      </div>

      <h2 style="margin-top:20px;">2) Solve / test</h2>

      <div class="checkline">
        <input id="strictEnd" type="checkbox" checked>
        <div>
          <b>Highest number must be the final cell</b>
          <div class="small">This matches the usual Zip puzzle behavior. Turn it off only if your puzzle variant allows continuing after the final number.</div>
        </div>
      </div>

      <label for="maxSearch">Search limit</label>
      <select id="maxSearch">
        <option value="100000">Quick - 100k attempts</option>
        <option value="500000">Medium - 500k attempts</option>
        <option value="2000000" selected>Deep - 2M attempts</option>
        <option value="8000000">Very Deep - 8M attempts</option>
      </select>

      <div class="btns">
        <button class="good" id="solveBtn">Auto Solve</button>
        <button id="checkBtn">Check Drawn Path</button>
        <button id="clearPathBtn">Clear Path</button>
        <button class="danger" id="clearAllBtn">Clear All</button>
      </div>

      <div id="status" class="status">
        Add the numbered dots, then click <b>Auto Solve</b>. You can also choose <b>Draw/Test</b> and try your own path manually.
      </div>

      <details open>
        <summary>How to use</summary>
        <ol>
          <li>Set the same row and column size as the LinkedIn puzzle.</li>
          <li>Choose <b>Place Number</b> and click each numbered dot location in order.</li>
          <li>Click <b>Auto Solve</b> to search for a full path that hits the numbers in order and fills every cell.</li>
          <li>Use the visual path or the directions list to try it on LinkedIn.</li>
        </ol>
      </details>
    </section>

    <section class="card board-wrap">
      <div class="toolbar">
        <div class="legend">
          <span><span class="swatch"></span> open cell</span>
          <span><span class="swatch path"></span> solved/tested path</span>
          <span><span class="swatch block"></span> blocked cell</span>
          <span><span class="pill">1</span> numbered dot</span>
        </div>
        <div class="small" id="boardInfo"></div>
      </div>

      <div class="grid-shell">
        <div id="grid"></div>
      </div>

      <div class="output">
        <div>
          <label for="directions">Directions</label>
          <textarea id="directions" readonly placeholder="Directions will appear here after solving."></textarea>
        </div>
        <div>
          <label for="pathCells">Cell-by-cell route</label>
          <textarea id="pathCells" readonly placeholder="Cell coordinates will appear here after solving."></textarea>
        </div>
      </div>
    </section>
  </main>

  <script>
    const gridEl = document.getElementById('grid');
    const rowsEl = document.getElementById('rows');
    const colsEl = document.getElementById('cols');
    const currentNumberEl = document.getElementById('currentNumber');
    const statusEl = document.getElementById('status');
    const directionsEl = document.getElementById('directions');
    const pathCellsEl = document.getElementById('pathCells');
    const boardInfoEl = document.getElementById('boardInfo');
    const strictEndEl = document.getElementById('strictEnd');
    const maxSearchEl = document.getElementById('maxSearch');

    let rows = 7;
    let cols = 7;
    let cells = [];
    let mode = 'number';
    let path = [];

    function newCell(){
      return { blocked:false, num:null };
    }

    function makeGrid(r = rows, c = cols){
      rows = clamp(parseInt(r,10) || 7, 2, 12);
      cols = clamp(parseInt(c,10) || 7, 2, 12);
      rowsEl.value = rows;
      colsEl.value = cols;
      cells = Array.from({length: rows * cols}, newCell);
      path = [];
      setStatus('Grid ready. Place the numbered dots from the puzzle.', 'warn');
      render();
    }

    function clamp(n,min,max){
      return Math.max(min, Math.min(max, n));
    }

    function indexToRC(i){
      return { r: Math.floor(i / cols), c: i % cols };
    }

    function rcToIndex(r,c){
      return r * cols + c;
    }

    function dotRing(num){
      const max = getMaxNumber() || Math.max(2, num);
      const t = max <= 1 ? 0 : (num - 1) / (max - 1);
      const purple = [192, 38, 211];
      const red = [239, 68, 68];
      const rgb = purple.map((v,i)=> Math.round(v + (red[i] - v) * t));
      return `rgb(${rgb[0]}, ${rgb[1]}, ${rgb[2]})`;
    }

    function pathColor(step, total){
      const t = total <= 1 ? 0 : step / (total - 1);
      const purple = [192, 38, 211];
      const red = [239, 68, 68];
      const rgb = purple.map((v,i)=> Math.round(v + (red[i] - v) * t));
      return `rgb(${rgb[0]}, ${rgb[1]}, ${rgb[2]})`;
    }

    function render(){
      gridEl.innerHTML = '';
      gridEl.style.gridTemplateColumns = `repeat(${cols}, var(--cell))`;

      const pathIndex = new Map();
      path.forEach((idx, step)=> pathIndex.set(idx, step));

      cells.forEach((cell, i)=>{
        const div = document.createElement('div');
        div.className = 'cell';
        div.dataset.index = i;

        if(cell.blocked) div.classList.add('blocked');

        if(pathIndex.has(i)){
          const step = pathIndex.get(i);
          div.classList.add('path');
          div.style.setProperty('--path-color', pathColor(step, path.length));
          div.dataset.step = step + 1;
          if(step === path.length - 1) div.classList.add('manual-last');
        }

        if(cell.num !== null && !cell.blocked){
          const dot = document.createElement('div');
          dot.className = 'dot';
          dot.textContent = cell.num;
          dot.style.setProperty('--dot-ring', dotRing(cell.num));
          div.appendChild(dot);
        }

        div.addEventListener('click', () => handleCellClick(i));
        gridEl.appendChild(div);
      });

      const free = cells.filter(c=>!c.blocked).length;
      const nums = cells.filter(c=>c.num !== null && !c.blocked).length;
      boardInfoEl.textContent = `${rows} x ${cols} • ${free} open cells • ${nums} numbered dots`;
    }

    function handleCellClick(i){
      if(mode === 'number'){
        const n = clamp(parseInt(currentNumberEl.value, 10) || 1, 1, 99);
        const existingAtNumber = cells.findIndex((cell, idx)=> idx !== i && cell.num === n && !cell.blocked);
        if(existingAtNumber >= 0) cells[existingAtNumber].num = null;
        cells[i].blocked = false;
        cells[i].num = n;
        currentNumberEl.value = n + 1;
        path = [];
      } else if(mode === 'block'){
        cells[i].blocked = !cells[i].blocked;
        if(cells[i].blocked) cells[i].num = null;
        path = [];
      } else if(mode === 'erase'){
        cells[i] = newCell();
        path = path.filter(idx => idx !== i);
      } else if(mode === 'draw'){
        drawCell(i);
      }
      updateOutputs();
      render();
    }

    function drawCell(i){
      if(cells[i].blocked) return;

      if(path.length === 0){
        const one = getNumberPositions().get(1);
        if(one !== undefined && i !== one){
          setStatus('Manual drawing should start on dot 1.', 'warn');
          return;
        }
        path = [i];
        setStatus('Path started. Click adjacent cells to continue.', 'warn');
        return;
      }

      const last = path[path.length - 1];

      if(i === last){
        path.pop();
        setStatus('Backed up one cell.', 'warn');
        return;
      }

      if(path.includes(i)){
        setStatus('That cell is already in the path.', 'bad');
        return;
      }

      if(!neighbors(last).includes(i)){
        setStatus('Next cell must be directly up, down, left, or right.', 'bad');
        return;
      }

      const validation = canStepManual(i);
      if(!validation.ok){
        setStatus(validation.message, 'bad');
        return;
      }

      path.push(i);
      const result = validatePath(path, false);
      if(result.complete){
        setStatus(result.message, 'good');
      } else if(result.ok){
        setStatus(result.message, 'warn');
      } else {
        setStatus(result.message, 'bad');
      }
      updateOutputs();
    }

    function canStepManual(i){
      const info = nextExpectedNumberForPath(path);
      const n = cells[i].num;
      if(n !== null && n !== info.next){
        return { ok:false, message:`You need to reach dot ${info.next} next, not dot ${n}.` };
      }
      return { ok:true };
    }

    function nextExpectedNumberForPath(testPath){
      let highestReached = 0;
      for(const idx of testPath){
        const n = cells[idx].num;
        if(n !== null && n === highestReached + 1){
          highestReached = n;
        }
      }
      return { reached: highestReached, next: highestReached + 1 };
    }

    function setMode(newMode){
      mode = newMode;
      document.querySelectorAll('#modeBtns button').forEach(btn=>{
        btn.classList.toggle('active', btn.dataset.mode === mode);
      });
      setStatus(
        mode === 'number' ? 'Number mode: click cells to place numbered dots.' :
        mode === 'draw' ? 'Draw/Test mode: click dot 1, then adjacent cells to test a path.' :
        mode === 'block' ? 'Block Cell mode: click cells to toggle unusable squares.' :
        'Erase mode: click cells to remove numbers, blocks, or path cells.',
        'warn'
      );
    }

    document.querySelectorAll('#modeBtns button').forEach(btn=>{
      btn.addEventListener('click', ()=>setMode(btn.dataset.mode));
    });

    document.getElementById('makeGridBtn').addEventListener('click', ()=>{
      makeGrid(rowsEl.value, colsEl.value);
    });

    document.getElementById('clearAllBtn').addEventListener('click', ()=>{
      if(confirm('Clear the entire board?')){
        makeGrid(rows, cols);
        directionsEl.value = '';
        pathCellsEl.value = '';
      }
    });

    document.getElementById('clearPathBtn').addEventListener('click', ()=>{
      path = [];
      updateOutputs();
      render();
      setStatus('Path cleared. Your dot placements stayed in place.', 'warn');
    });

    document.getElementById('checkBtn').addEventListener('click', ()=>{
      const result = validatePath(path, true);
      setStatus(result.message, result.ok ? (result.complete ? 'good' : 'warn') : 'bad');
    });

    document.getElementById('solveBtn').addEventListener('click', ()=>{
      solvePuzzle();
    });

    document.getElementById('sampleBtn').addEventListener('click', ()=>{
      loadSample();
    });

    function getMaxNumber(){
      return Math.max(0, ...cells.map(c=> c.blocked || c.num === null ? 0 : c.num));
    }

    function getNumberPositions(){
      const positions = new Map();
      cells.forEach((cell, idx)=>{
        if(!cell.blocked && cell.num !== null) positions.set(cell.num, idx);
      });
      return positions;
    }

    function neighbors(idx){
      const {r,c} = indexToRC(idx);
      const out = [];
      if(r > 0) out.push(rcToIndex(r-1,c));
      if(r < rows - 1) out.push(rcToIndex(r+1,c));
      if(c > 0) out.push(rcToIndex(r,c-1));
      if(c < cols - 1) out.push(rcToIndex(r,c+1));
      return out;
    }

    function validateNumbers(){
      const positions = getNumberPositions();
      const nums = [...positions.keys()].sort((a,b)=>a-b);
      if(nums.length < 2){
        return { ok:false, message:'Place at least dot 1 and dot 2 before solving.' };
      }
      if(nums[0] !== 1){
        return { ok:false, message:'The lowest dot must be 1.' };
      }
      for(let n = 1; n <= nums[nums.length - 1]; n++){
        if(!positions.has(n)) return { ok:false, message:`Missing dot ${n}. Numbers must be consecutive.` };
      }
      return { ok:true, positions, max: nums[nums.length - 1] };
    }

    function validatePath(testPath, finalCheck){
      const nums = validateNumbers();
      if(!nums.ok) return {ok:false, complete:false, message:nums.message};
      if(testPath.length === 0) return {ok:false, complete:false, message:'No path has been drawn or solved yet.'};

      const freeCount = cells.filter(c=>!c.blocked).length;
      const used = new Set();
      let expected = 1;

      for(let step = 0; step < testPath.length; step++){
        const idx = testPath[step];
        if(cells[idx].blocked) return {ok:false, complete:false, message:'The path uses a blocked cell.'};
        if(used.has(idx)) return {ok:false, complete:false, message:'The path repeats a cell.'};
        used.add(idx);

        if(step > 0 && !neighbors(testPath[step-1]).includes(idx)){
          return {ok:false, complete:false, message:'The path has a jump. Every step must be adjacent.'};
        }

        const n = cells[idx].num;
        if(n !== null){
          if(n !== expected){
            return {ok:false, complete:false, message:`The path hit dot ${n}, but dot ${expected} was expected.`};
          }
          expected++;
        }
      }

      if(testPath[0] !== nums.positions.get(1)){
        return {ok:false, complete:false, message:'The path must start on dot 1.'};
      }

      const reachedThrough = expected - 1;
      const complete = testPath.length === freeCount && reachedThrough === nums.max;
      if(complete){
        if(strictEndEl.checked && testPath[testPath.length - 1] !== nums.positions.get(nums.max)){
          return {ok:false, complete:false, message:`All cells are filled, but the final cell is not dot ${nums.max}.`};
        }
        return {ok:true, complete:true, message:'Looks good: every open cell is filled and the dots are reached in order.'};
      }

      if(finalCheck){
        const missing = freeCount - testPath.length;
        return {ok:true, complete:false, message:`Partial path is valid so far. ${missing} open cells still need to be filled. Reached dot ${reachedThrough}.`};
      }

      return {ok:true, complete:false, message:`Valid so far. Reached dot ${reachedThrough}; next dot is ${expected}.`};
    }

    function solvePuzzle(){
      const validation = validateNumbers();
      if(!validation.ok){
        setStatus(validation.message, 'bad');
        return;
      }

      const freeCount = cells.filter(c=>!c.blocked).length;
      const maxAttempts = parseInt(maxSearchEl.value, 10);
      const strictEnd = strictEndEl.checked;
      const start = validation.positions.get(1);
      const finalPos = validation.positions.get(validation.max);
      const maxNum = validation.max;
      const startTime = performance.now();

      const visited = new Uint8Array(rows * cols);
      visited[start] = 1;
      const currentPath = [start];

      let attempts = 0;
      let prunes = 0;
      let found = null;

      setStatus('Solving... The page may pause briefly on harder boards.', 'warn');

      function cellNumber(idx){
        return cells[idx].blocked ? null : cells[idx].num;
      }

      function isAllowedMove(idx, nextTarget){
        if(idx < 0 || idx >= cells.length) return false;
        if(cells[idx].blocked || visited[idx]) return false;

        const n = cellNumber(idx);
        if(n === null) return true;

        if(nextTarget <= maxNum && n === nextTarget) return true;

        if(!strictEnd && nextTarget > maxNum) return true;

        return false;
      }

      function nextTargetAfterMove(idx, nextTarget){
        const n = cellNumber(idx);
        if(n !== null && n === nextTarget) return nextTarget + 1;
        return nextTarget;
      }

      function allowedNeighborsFrom(idx, nextTarget){
        return neighbors(idx).filter(nIdx => isAllowedMove(nIdx, nextTarget));
      }

      function canReachNextDot(cur, nextTarget){
        if(nextTarget > maxNum) return true;
        const target = validation.positions.get(nextTarget);
        const queue = [cur];
        const seen = new Uint8Array(rows * cols);
        seen[cur] = 1;

        for(let head = 0; head < queue.length; head++){
          const here = queue[head];
          if(here === target) return true;

          for(const nb of neighbors(here)){
            if(seen[nb] || cells[nb].blocked) continue;
            if(visited[nb] && nb !== cur) continue;

            const n = cellNumber(nb);
            if(n !== null && n !== nextTarget && nb !== cur) continue;

            seen[nb] = 1;
            queue.push(nb);
          }
        }
        return false;
      }

      function connectivityOkay(cur){
        const queue = [cur];
        const seen = new Uint8Array(rows * cols);
        seen[cur] = 1;
        let count = 0;

        for(let head = 0; head < queue.length; head++){
          const here = queue[head];
          count++;
          for(const nb of neighbors(here)){
            if(seen[nb] || cells[nb].blocked) continue;
            if(visited[nb] && nb !== cur) continue;
            seen[nb] = 1;
            queue.push(nb);
          }
        }

        const remainingPlusCurrent = (freeCount - currentPath.length) + 1;
        return count === remainingPlusCurrent;
      }

      function hasIsolatedUnvisitedCell(cur){
        for(let i = 0; i < cells.length; i++){
          if(cells[i].blocked || visited[i]) continue;
          let deg = 0;
          for(const nb of neighbors(i)){
            if(cells[nb].blocked) continue;
            if(!visited[nb] || nb === cur) deg++;
          }
          if(deg === 0) return true;
        }
        return false;
      }

      function orderedMoves(cur, nextTarget){
        const target = nextTarget <= maxNum ? validation.positions.get(nextTarget) : finalPos;
        const moves = allowedNeighborsFrom(cur, nextTarget);

        moves.sort((a,b)=>{
          const aTarget = nextTargetAfterMove(a, nextTarget);
          const bTarget = nextTargetAfterMove(b, nextTarget);

          visited[a] = 1;
          const aDeg = allowedNeighborsFrom(a, aTarget).length;
          visited[a] = 0;

          visited[b] = 1;
          const bDeg = allowedNeighborsFrom(b, bTarget).length;
          visited[b] = 0;

          const ar = indexToRC(a), br = indexToRC(b), tr = indexToRC(target);
          const aDist = Math.abs(ar.r - tr.r) + Math.abs(ar.c - tr.c);
          const bDist = Math.abs(br.r - tr.r) + Math.abs(br.c - tr.c);

          const aIsTarget = a === target ? -3 : 0;
          const bIsTarget = b === target ? -3 : 0;

          return (aDeg + aDist * 0.08 + aIsTarget) - (bDeg + bDist * 0.08 + bIsTarget);
        });

        return moves;
      }

      function dfs(cur, nextTarget){
        attempts++;

        if(attempts > maxAttempts) return false;

        if(currentPath.length === freeCount){
          if(nextTarget <= maxNum) return false;
          if(strictEnd && cur !== finalPos) return false;
          found = currentPath.slice();
          return true;
        }

        if(strictEnd && nextTarget > maxNum) return false;

        if(attempts % 250 === 0){
          if(!connectivityOkay(cur)){ prunes++; return false; }
          if(hasIsolatedUnvisitedCell(cur)){ prunes++; return false; }
          if(!canReachNextDot(cur, nextTarget)){ prunes++; return false; }
        } else {
          if(!canReachNextDot(cur, nextTarget)){ prunes++; return false; }
        }

        const moves = orderedMoves(cur, nextTarget);

        for(const move of moves){
          const afterTarget = nextTargetAfterMove(move, nextTarget);
          visited[move] = 1;
          currentPath.push(move);

          if(dfs(move, afterTarget)) return true;

          currentPath.pop();
          visited[move] = 0;
        }

        return false;
      }

      const ok = dfs(start, 2);
      const elapsed = ((performance.now() - startTime) / 1000).toFixed(2);

      if(ok && found){
        path = found;
        updateOutputs();
        render();
        setStatus(`Solved in ${elapsed}s after ${attempts.toLocaleString()} attempts. Use the directions below to recreate the route.`, 'good');
      } else {
        render();
        const reason = attempts > maxAttempts ? `Reached the ${maxAttempts.toLocaleString()} attempt limit.` : 'No route found with the current settings.';
        setStatus(`${reason} Check the dot locations, increase the search limit, or try turning off “highest number must be final” if your puzzle variant allows that. Attempts: ${attempts.toLocaleString()}, prunes: ${prunes.toLocaleString()}, time: ${elapsed}s.`, 'bad');
      }
    }

    function updateOutputs(){
      if(path.length < 2){
        directionsEl.value = '';
        pathCellsEl.value = path.length === 1 ? cellLabel(path[0]) : '';
        return;
      }

      const dirs = [];
      const labels = [];

      for(let i = 0; i < path.length; i++){
        labels.push(`${i+1}. ${cellLabel(path[i])}${cells[path[i]].num ? '  dot ' + cells[path[i]].num : ''}`);
        if(i > 0){
          const a = indexToRC(path[i-1]);
          const b = indexToRC(path[i]);
          if(b.r === a.r - 1) dirs.push('U');
          else if(b.r === a.r + 1) dirs.push('D');
          else if(b.c === a.c - 1) dirs.push('L');
          else if(b.c === a.c + 1) dirs.push('R');
          else dirs.push('?');
        }
      }

      directionsEl.value = compressDirections(dirs);
      pathCellsEl.value = labels.join('\n');
    }

    function cellLabel(idx){
      const {r,c} = indexToRC(idx);
      return `R${r+1}C${c+1}`;
    }

    function compressDirections(dirs){
      if(!dirs.length) return '';
      const lines = [];
      let prev = dirs[0];
      let count = 1;

      for(let i = 1; i < dirs.length; i++){
        if(dirs[i] === prev) count++;
        else {
          lines.push(count > 1 ? `${prev} x${count}` : prev);
          prev = dirs[i];
          count = 1;
        }
      }
      lines.push(count > 1 ? `${prev} x${count}` : prev);

      const long = dirs.map(d => ({U:'Up',D:'Down',L:'Left',R:'Right'}[d] || d)).join(' → ');
      return `Compressed:\n${lines.join(' → ')}\n\nStep-by-step:\n${long}`;
    }

    function setStatus(message, type){
      statusEl.className = `status ${type || ''}`;
      statusEl.innerHTML = message;
    }

    function loadSample(){
      rows = 5;
      cols = 5;
      rowsEl.value = rows;
      colsEl.value = cols;
      cells = Array.from({length: rows * cols}, newCell);
      const sampleDots = [
        [1,4,1],
        [2,2,1],
        [3,0,1],
        [4,0,3],
        [5,4,4]
      ];
      sampleDots.forEach(([num,r,c])=>{
        cells[rcToIndex(r,c)].num = num;
      });
      path = [];
      currentNumberEl.value = 6;
      setStatus('Sample loaded. Click Auto Solve to see how it works, then clear and build your own.', 'warn');
      updateOutputs();
      render();
    }

    makeGrid(7,7);
  </script>
</body>
