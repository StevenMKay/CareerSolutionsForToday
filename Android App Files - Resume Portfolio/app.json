{
  "expo": {
    "name": "Career Resume Builder",
    "slug": "resume-portfolio",
    "version": "1.0.6",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "careerresumebuilder",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.careersolutionsfortoday.resumebuilder",
      "infoPlist": {
        "NSCameraUsageDescription": "Add a profile photo to your resume",
        "NSPhotoLibraryUsageDescription": "Attach photos and resume files",
        "NSMicrophoneUsageDescription": "Record voice notes in the resume builder"
      }
    },
    "android": {
      "package": "com.careersolutionsfortoday.resumebuilder",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F172A"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b8616cbf-dcf3-4209-94a4-1b5e2349c7bc"
      }
    },
    "owner": "career-solutions-for-today"
  }
}
