# ============================================================
# .gitignore - Career Solutions for Today
# ============================================================

# --- Secrets & credentials (CRITICAL - never commit these) ---
backend/.env
backend/serviceAccountKey.json
**/.env
**/.env.local
**/.env.production
**/serviceAccountKey.json

# --- API keys in text files ---
*.txt
!README.txt
!robots.txt

# --- Node dependencies ---
node_modules/
backend/node_modules/
career_community/node_modules/

# --- Local Android wrapper working copy (tracked version lives in
#     "Android App Files - Resume Portfolio/") ---
Android App Files/

# --- Python ---
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editor ---
.vscode/settings.json
*.swp
*.swo

# --- Build outputs ---
dist/
build/
.vercel/
